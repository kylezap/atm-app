{
  "name": "atm-app",
  "private": true,
  "version": "1.0.0",
  "description": "Lightweight ATM app monorepo scaffold.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev --workspace @atm/api\" \"npm run dev --workspace @atm/web\"",
    "dev:api": "npm run dev --workspace @atm/api",
    "dev:web": "npm run dev --workspace @atm/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kylezap/atm-app.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kylezap/atm-app/issues"
  },
  "homepage": "https://github.com/kylezap/atm-app#readme",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
